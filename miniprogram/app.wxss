/* 全局样式 - Executive Portfolio 设计规范 */
/* 主色: #3a5f94, 背景: #f8f9fa, 文本: #2b3437 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #2b3437;
  background-color: #f8f9fa;
  line-height: 1.5;
}

/* ---------- 颜色系统 ---------- */
.color-primary { color: #3a5f94; }
.color-on-surface { color: #2b3437; }
.color-on-surface-variant { color: #586064; }
.color-error { color: #9f403d; }
.color-on-primary { color: #f6f7ff; }

.bg-surface { background-color: #f8f9fa; }
.bg-surface-container-low { background-color: #f1f4f6; }
.bg-surface-container-lowest { background-color: #ffffff; }
.bg-primary { background-color: #3a5f94; }

/* ---------- 签名渐变 ---------- */
.signature-gradient {
  background: linear-gradient(135deg, #3a5f94 0%, #375c91 100%);
}

/* ---------- 毛玻璃 ---------- */
.glass-panel {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(24px);
}

/* ---------- 排版 ---------- */
.headline-lg {
  font-weight: 800;
  font-size: 36rpx;
  letter-spacing: -0.5rpx;
}
.headline-sm {
  font-weight: 700;
  font-size: 32rpx;
}
.body-md {
  font-weight: 400;
  font-size: 28rpx;
  color: #586064;
}
.body-sm {
  font-weight: 400;
  font-size: 24rpx;
  color: #586064;
}
.label-md {
  font-weight: 600;
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* ---------- 圆角 ---------- */
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 24rpx; }
.rounded-full { border-radius: 9999rpx; }

/* ---------- 通用布局 ---------- */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ---------- 卡片 ---------- */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* ---------- 按钮 ---------- */
.btn-primary {
  background: linear-gradient(135deg, #3a5f94 0%, #375c91 100%);
  color: #f6f7ff;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-weight: 700;
  font-size: 32rpx;
  text-align: center;
  border: none;
}
.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: #f1f4f6;
  color: #3a5f94;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-weight: 600;
  font-size: 28rpx;
  text-align: center;
  border: none;
}

/* ---------- 输入框 ---------- */
.input-field {
  width: 100%;
  padding: 24rpx 32rpx;
  background: #f1f4f6;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  box-sizing: border-box;
}
.input-field:focus {
  background: #ffffff;
  box-shadow: 0 0 0 2rpx rgba(58, 95, 148, 0.3);
}

/* ---------- 隐藏滚动条 ---------- */
.no-scrollbar::-webkit-scrollbar {
  display: none;
}

/* ---------- 安全区底部 ---------- */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
