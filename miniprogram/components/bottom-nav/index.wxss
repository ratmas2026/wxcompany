.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 12rpx 32rpx 16rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 48rpx rgba(43, 52, 55, 0.06);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
  color: #94a3b8;
}

.tab-active {
  color: #3a5f94;
  background: rgba(58, 95, 148, 0.05);
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}
