<template name="textBox">
  <block wx:if="{{tb.role && tb.role.name}}">
    <view class="profile-card-role" style="text-align:{{tb.textAlign}}">
      <view class="profile-card-role-inner">
        <image wx:if="{{tb.role.avatar}}" class="profile-card-role-avatar" src="{{tb.role.avatar}}" mode="aspectFill" />
        <view class="profile-card-role-text">
          <view class="profile-card-text" style="font-family:{{tb.fontFamily}};font-size:{{tb.fontSizeRpx}}">{{tb.role.name}}</view>
          <view class="profile-card-role-title" style="font-family:{{tb.fontFamily}}">{{tb.role.title}}</view>
        </view>
      </view>
    </view>
  </block>
  <view wx:else class="profile-card-text" style="font-family:{{tb.fontFamily}};font-size:{{tb.fontSizeRpx}};text-align:{{tb.textAlign}}">{{tb.text || ''}}</view>
</template>

<scroll-view scroll-y type="custom" class="page-container" enable-flex>
  <top-bar title="名片" icon="📇" showBack="{{false}}" />

  <!-- 骨架屏：数据加载中 -->
  <block wx:if="{{!isDataReady}}">
    <view class="skeleton-hero">
      <view class="skeleton-line skeleton-line-short"></view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line skeleton-line-medium"></view>
    </view>
    <view class="skeleton-section">
      <view class="skeleton-title"></view>
      <view class="skeleton-card"></view>
    </view>
  </block>

  <!-- 真实内容：数据就绪后渲染 -->
  <block wx:else>
  <!-- 名片卡片 -->
  <view class="card-section">
    <view class="business-card signature-gradient">
      <view class="card-bg-blur"></view>
      <view class="card-avatar">
        <image class="avatar-img" src="{{cardData.avatar || '/images/avatar-executive.jpg'}}" mode="aspectFill" />
      </view>
      <view class="card-info">
        <text class="card-name">{{cardData.name}}</text>
        <text class="card-title">{{cardData.title}}</text>
        <view class="card-badge">
          <text>{{cardData.department || companyInfo.name || '高级管理合伙人'}}</text>
        </view>
      </view>
      <view class="card-contact">
        <view class="contact-row" bindtap="callPhone">
          <view class="contact-icon">
            <text>📞</text>
          </view>
          <text>立即通话</text>
        </view>
        <view class="contact-row" bindtap="sendEmail">
          <view class="contact-icon">
            <text>📧</text>
          </view>
          <text>发送邮件</text>
        </view>
      </view>
      <view class="card-location" bindtap="openMap">
        <text>📍</text>
        <view class="location-info">
          <text class="location-company">{{matchedCI.name || cardData.company}}</text>
          <text class="location-addr">{{matchedCI.address || cardData.address || companyInfo.address || '深圳市南山区科技园南路88号智能大厦38层'}}</text>
        </view>
        <text class="location-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 快速操作 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="shareCard">
      <view class="action-icon"><text>📤</text></view>
      <text>推送</text>
    </view>
    <view class="action-item" bindtap="generatePoster">
      <view class="action-icon"><text>🖼️</text></view>
      <text>海报</text>
    </view>
    <view class="action-item" bindtap="collectCard">
      <view class="action-icon"><text>❤️</text></view>
      <text>收藏</text>
    </view>
  </view>

  <!-- 企业动态 -->
  <view wx:if="{{showProfiles}}" class="module-block">
    <view class="section-header">
      <text class="section-headline">{{profilesModuleName}}</text>
    </view>
    <!-- Hero区 - 企业动态ARC卡片 -->
    <block wx:if="{{heroCard}}">
      <view class="hero-card-wrap">
      <view class="hero-section" style="height:{{heroCard._height}}rpx; padding:32rpx 28rpx; box-sizing:border-box; background-color:#f3f4f6" bindtap="onCoverCardTap" data-profile="{{heroCard}}">
        <image wx:if="{{heroCard.cover.backgroundImage}}" class="hero-bg-image" src="{{heroCard.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === heroCard.id}}" />
        <view class="hero-content" hidden="{{playingCardId === heroCard.id}}">
          <block wx:for="{{heroCard.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
            <template is="textBox" data="{{tb}}" />
          </block>
          <view class="hero-card-middle">
            <block wx:for="{{heroCard.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
              <template is="textBox" data="{{tb}}" />
            </block>
          </view>
          <block wx:for="{{heroCard.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
            <template is="textBox" data="{{tb}}" />
          </block>
          <rich-text wx:if="{{heroCard.cover.body}}" nodes="{{heroCard.cover.body}}" class="cover-body-rich"></rich-text>
          <view wx:if="{{heroCard.cover.video}}" class="hero-video-btn" data-profile="{{heroCard}}" catchtap="onCoverVideoTap">
            <text class="profile-card-play-icon">▶</text>
          </view>
        </view>
        <video wx:if="{{playingCardId === heroCard.id}}" id="vid-{{heroCard.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{heroCard.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
        <view wx:if="{{playingCardId === heroCard.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
      </view>
      </view>
    </block>
    <block wx:if="{{sections.length > 0}}">
      <view wx:for="{{sections}}" wx:key="id" class="profile-section">
        <view wx:if="{{sections.length > 1}}" class="profile-section-divider">
          <view class="profile-section-line"></view>
        </view>
        <!-- Hero 卡片 -->
        <view wx:if="{{item.displayLayout === 'hero'}}">
          <view wx:for="{{item.cards}}" wx:for-item="card" wx:key="id"
            class="hero-section" style="height:{{card._height}}rpx; padding:32rpx 28rpx; box-sizing:border-box; background-color:#f3f4f6"
            bindtap="onCoverCardTap" data-profile="{{card}}">
            <image wx:if="{{card.cover.backgroundImage}}" class="hero-bg-image" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
            <view class="hero-content" hidden="{{playingCardId === card.id}}">
              <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <view class="hero-card-middle">
                <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
              </view>
              <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
              <view wx:if="{{card.cover.video}}" class="hero-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                <text class="profile-card-play-icon">▶</text>
              </view>
            </view>
            <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
            <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
          </view>
        </view>
        <!-- 单张展示 -->
        <view wx:if="{{item.displayLayout === 'single'}}" class="profile-single">
          <view
            wx:for="{{item.cards}}"
            wx:for-item="card"
            wx:key="id"
            class="profile-card profile-card-single"
            style="height:{{card._height}}rpx"
            data-profile="{{card}}"
            bindtap="onCoverCardTap"
          >
            <image wx:if="{{card.cover.backgroundImage}}" class="profile-card-bg" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
            <view class="profile-card-overlay" hidden="{{playingCardId === card.id}}">
              <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <view class="profile-card-middle">
                <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
              </view>
              <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
              <view wx:if="{{card.cover.video}}" class="profile-card-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                <text class="profile-card-play-icon">▶</text>
              </view>
            </view>
            <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
            <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
          </view>
        </view>

        <!-- 横滚布局 -->
        <scroll-view wx:if="{{item.displayLayout === 'horizontal-scroll'}}" scroll-x type="custom" class="profile-scroll" enable-flex>
          <view class="profile-scroll-inner">
            <view
              wx:for="{{item.cards}}"
              wx:for-item="card"
              wx:key="id"
              class="profile-card profile-card-hscroll"
              style="height:{{card._height}}rpx"
              data-profile="{{card}}"
              bindtap="onCoverCardTap"
            >
              <image wx:if="{{card.cover.backgroundImage}}" class="profile-card-bg" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
              <view class="profile-card-overlay" hidden="{{playingCardId === card.id}}">
                <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
                <view class="profile-card-middle">
                  <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                    <template is="textBox" data="{{tb}}" />
                  </block>
                </view>
                <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
                <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
                <view wx:if="{{card.cover.video}}" class="profile-card-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                  <text class="profile-card-play-icon">▶</text>
                </view>
              </view>
              <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
              <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
              <view wx:if="{{card.detail.detailEntry && !card.cover.video}}" class="profile-card-entry">
                <text>查看详情 →</text>
              </view>
            </view>
          </view>
        </scroll-view>

        <!-- 宫格布局 -->
        <view wx:if="{{item.displayLayout === 'grid'}}" class="profile-grid g-active" style="display:grid;grid-template-columns:repeat({{item.gridCols}},1fr);gap:{{item.gridCols === 3 ? '16' : '20'}}rpx">
          <view
            wx:for="{{item.cards}}"
            wx:for-item="card"
            wx:key="id"
            class="profile-card profile-card-grid"
            style="height:{{card._height}}rpx"
            data-profile="{{card}}"
            bindtap="onCoverCardTap"
          >
            <image wx:if="{{card.cover.backgroundImage}}" class="profile-card-bg" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
            <view class="profile-card-overlay" hidden="{{playingCardId === card.id}}">
              <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <view class="profile-card-middle">
                <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
              </view>
              <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
              <view wx:if="{{card.cover.video}}" class="profile-card-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                <text class="profile-card-play-icon">▶</text>
              </view>
            </view>
            <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
            <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
          </view>
        </view>

        <!-- Tab标签页 -->
        <view wx:if="{{item.displayLayout === 'tab'}}" class="tab-section">
          <scroll-view wx:if="{{item.tabLayout === 'scroll'}}" scroll-x type="custom" class="tab-headers-scroll" enable-flex>
            <view class="tab-headers-inner">
              <view wx:for="{{item.tabs}}" wx:for-item="tab" wx:for-index="tabIdx" wx:key="title"
                class="tab-header {{item.activeTab === tabIdx ? 'tab-header-active' : ''}}"
                data-section-id="{{item.id}}" data-tab-index="{{tabIdx}}" bindtap="onTabSwitch">
                <text>{{tab.title}}</text>
              </view>
            </view>
          </scroll-view>
          <view wx:else class="tab-headers-fixed">
            <view wx:for="{{item.tabs}}" wx:for-item="tab" wx:for-index="tabIdx" wx:key="title"
              class="tab-header {{item.activeTab === tabIdx ? 'tab-header-active' : ''}}"
              data-section-id="{{item.id}}" data-tab-index="{{tabIdx}}" bindtap="onTabSwitch">
              <text>{{tab.title}}</text>
            </view>
          </view>
          <!-- 每页1张：全宽单张样式 -->
          <view wx:if="{{item.tabPerPage === 1}}" class="profile-single">
            <view wx:for="{{item.currentTabCards}}" wx:for-item="card" wx:key="id"
              class="profile-card profile-card-single" style="height:{{card._height}}rpx"
              data-profile="{{card}}" bindtap="onCoverCardTap">
              <image wx:if="{{card.cover.backgroundImage}}" class="profile-card-bg" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
              <view class="profile-card-overlay" hidden="{{playingCardId === card.id}}">
                <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
                <view class="profile-card-middle">
                  <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                    <template is="textBox" data="{{tb}}" />
                  </block>
                </view>
                <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
                <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
                <view wx:if="{{card.cover.video}}" class="profile-card-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                  <text class="profile-card-play-icon">▶</text>
                </view>
              </view>
              <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
              <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
              <view wx:if="{{card.detail.detailEntry && !card.cover.video}}" class="profile-card-entry">
                <text>查看详情 →</text>
              </view>
            </view>
          </view>
          <!-- 每页多张：网格样式 -->
          <view wx:else class="profile-grid g-active" style="display:grid;grid-template-columns:repeat(2,1fr);gap:20rpx">
            <view wx:for="{{item.currentTabCards}}" wx:for-item="card" wx:key="id"
              class="profile-card profile-card-grid" style="height:{{card._height}}rpx"
              data-profile="{{card}}" bindtap="onCoverCardTap">
              <image wx:if="{{card.cover.backgroundImage}}" class="profile-card-bg" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
              <view class="profile-card-overlay" hidden="{{playingCardId === card.id}}">
                <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
                <view class="profile-card-middle">
                  <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                    <template is="textBox" data="{{tb}}" />
                  </block>
                </view>
                <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
                <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
                <view wx:if="{{card.cover.video}}" class="profile-card-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                  <text class="profile-card-play-icon">▶</text>
                </view>
              </view>
              <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
              <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
              <view wx:if="{{card.detail.detailEntry && !card.cover.video}}" class="profile-card-entry">
                <text>查看详情 →</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 无卡片时不渲染 -->
  </view>

  <!-- 公司业绩 -->
  <view wx:if="{{showPerformance}}" class="module-block">
    <view class="section-header">
      <text class="section-headline">{{performanceModuleName}}</text>
    </view>
    <block wx:if="{{performanceHeroCard}}">
      <view class="hero-section" style="height:{{performanceHeroCard._height}}rpx; padding:32rpx 28rpx; box-sizing:border-box; background-color:#f3f4f6" bindtap="onPerformanceCardTap" data-profile="{{performanceHeroCard}}">
        <image wx:if="{{performanceHeroCard.cover.backgroundImage}}" class="hero-bg-image" src="{{performanceHeroCard.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === performanceHeroCard.id}}" />
        <view class="hero-content" hidden="{{playingCardId === performanceHeroCard.id}}">
          <block wx:for="{{performanceHeroCard.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
            <template is="textBox" data="{{tb}}" />
          </block>
          <view class="hero-card-middle">
            <block wx:for="{{performanceHeroCard.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
              <template is="textBox" data="{{tb}}" />
            </block>
          </view>
          <block wx:for="{{performanceHeroCard.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
            <template is="textBox" data="{{tb}}" />
          </block>
          <rich-text wx:if="{{performanceHeroCard.cover.body}}" nodes="{{performanceHeroCard.cover.body}}" class="cover-body-rich"></rich-text>
          <view wx:if="{{performanceHeroCard.cover.video}}" class="hero-video-btn" data-profile="{{performanceHeroCard}}" catchtap="onCoverVideoTap">
            <text class="profile-card-play-icon">▶</text>
          </view>
        </view>
        <video wx:if="{{playingCardId === performanceHeroCard.id}}" id="vid-{{performanceHeroCard.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{performanceHeroCard.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
        <view wx:if="{{playingCardId === performanceHeroCard.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
      </view>
    </block>
    <block wx:if="{{performanceSections.length > 0}}">
      <view wx:for="{{performanceSections}}" wx:key="id" class="profile-section">
        <view wx:if="{{performanceSections.length > 1}}" class="profile-section-divider">
          <view class="profile-section-line"></view>
        </view>
        <view wx:if="{{item.displayLayout === 'single'}}" class="profile-single">
          <view
            wx:for="{{item.cards}}"
            wx:for-item="card"
            wx:key="id"
            class="profile-card profile-card-single"
            style="height:{{card._height}}rpx"
            data-profile="{{card}}"
            bindtap="onPerformanceCardTap"
          >
            <image wx:if="{{card.cover.backgroundImage}}" class="profile-card-bg" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
            <view class="profile-card-overlay" hidden="{{playingCardId === card.id}}">
              <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <view class="profile-card-middle">
                <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
              </view>
              <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
              <view wx:if="{{card.cover.video}}" class="profile-card-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                <text class="profile-card-play-icon">▶</text>
              </view>
            </view>
            <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
            <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
          </view>
        </view>

        <scroll-view wx:if="{{item.displayLayout === 'horizontal-scroll'}}" scroll-x type="custom" class="profile-scroll" enable-flex>
          <view class="profile-scroll-inner">
            <view
              wx:for="{{item.cards}}"
              wx:for-item="card"
              wx:key="id"
              class="profile-card profile-card-hscroll"
              style="height:{{card._height}}rpx"
              data-profile="{{card}}"
              bindtap="onPerformanceCardTap"
            >
              <image wx:if="{{card.cover.backgroundImage}}" class="profile-card-bg" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
              <view class="profile-card-overlay" hidden="{{playingCardId === card.id}}">
                <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
                <view class="profile-card-middle">
                  <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                    <template is="textBox" data="{{tb}}" />
                  </block>
                </view>
                <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
                <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
                <view wx:if="{{card.cover.video}}" class="profile-card-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                  <text class="profile-card-play-icon">▶</text>
                </view>
              </view>
              <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
              <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
              <view wx:if="{{card.detail.detailEntry && !card.cover.video}}" class="profile-card-entry">
                <text>查看详情 →</text>
              </view>
            </view>
          </view>
        </scroll-view>

        <view wx:if="{{item.displayLayout === 'grid'}}" class="profile-grid g-active" style="display:grid;grid-template-columns:repeat({{item.gridCols}},1fr);gap:{{item.gridCols === 3 ? '16' : '20'}}rpx">
          <view
            wx:for="{{item.cards}}"
            wx:for-item="card"
            wx:key="id"
            class="profile-card profile-card-grid"
            style="height:{{card._height}}rpx"
            data-profile="{{card}}"
            bindtap="onPerformanceCardTap"
          >
            <image wx:if="{{card.cover.backgroundImage}}" class="profile-card-bg" src="{{card.cover.backgroundImage}}" mode="aspectFill" hidden="{{playingCardId === card.id}}" />
            <view class="profile-card-overlay" hidden="{{playingCardId === card.id}}">
              <block wx:for="{{card.cover.zones.top.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <view class="profile-card-middle">
                <block wx:for="{{card.cover.zones.middle.textBoxes}}" wx:for-item="tb" wx:key="id">
                  <template is="textBox" data="{{tb}}" />
                </block>
              </view>
              <block wx:for="{{card.cover.zones.bottom.textBoxes}}" wx:for-item="tb" wx:key="id">
                <template is="textBox" data="{{tb}}" />
              </block>
              <rich-text wx:if="{{card.cover.body}}" nodes="{{card.cover.body}}" class="cover-body-rich"></rich-text>
              <view wx:if="{{card.cover.video}}" class="profile-card-video-btn" data-profile="{{card}}" catchtap="onCoverVideoTap">
                <text class="profile-card-play-icon">▶</text>
              </view>
            </view>
            <video wx:if="{{playingCardId === card.id}}" id="vid-{{card.id}}" style="position:absolute;top:0;left:0;width:100%;height:100%" src="{{card.cover.video}}" object-fit="fill" show-fullscreen-btn="{{false}}" enable-play-gesture="{{false}}" controls />
            <view wx:if="{{playingCardId === card.id}}" class="inline-video-close" catchtap="closeInlineVideo">✕</view>
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="intro-card card">
        <text class="section-title">公司业绩</text>
        <text class="section-desc">展示企业发展历程中的重要里程碑和卓越成就。</text>
      </view>
    </block>
  </view>

  <!-- 核心业务 -->
  <view wx:if="{{showBusiness}}" class="module-block">
    <view class="section-header">
      <text class="section-headline">{{businessModuleName}}</text>
    </view>
    <block wx:if="{{businessHeroCards.length > 0}}">
      <view class="hero-card-wrap">
      <view wx:for="{{businessHeroCards}}" wx:for-item="hero" wx:key="id"
        class="hero-section"
        style="height:{{hero._height}}rpx; padding:32rpx 28rpx; box-sizing:border-box; background-color:#f3f4f6"
        bindtap="onBizCardTap" data-module-id="{{hero.id}}">
        <image wx:if="{{hero.coverImage}}" class="hero-bg-image" src="{{hero.coverImage}}" mode="aspectFill" />
        <view class="hero-content">
          <view class="hero-card-middle">
            <view class="profile-card-text" style="font-size:32rpx;text-align:center;color:#fff">{{hero.name}}</view>
          </view>
        </view>
      </view>
      </view>
    </block>
    <block wx:if="{{businessSections.length > 0}}">
      <view wx:for="{{businessSections}}" wx:key="id" class="profile-section">
        <view wx:if="{{businessSections.length > 1}}" class="profile-section-divider">
          <view class="profile-section-line"></view>
        </view>
        <view wx:if="{{item.displayLayout === 'single'}}" class="profile-single">
          <view wx:for="{{item.cards}}" wx:for-item="card" wx:key="id"
            class="biz-card biz-card-single" style="height:{{card._height}}rpx"
            bindtap="onBizCardTap" data-module-id="{{card.id}}">
            <image wx:if="{{card.coverImage}}" class="biz-card-cover" src="{{card.coverImage}}" mode="aspectFill" />
            <view class="biz-card-info">
              <text class="biz-card-name">{{card.name}}</text>

            </view>
          </view>
        </view>
        <swiper wx:if="{{item.displayLayout === 'horizontal-scroll'}}"
          class="profile-swiper"
          indicator-dots="{{item.cards.length > 1}}"
          indicator-color="rgba(255,255,255,0.4)"
          indicator-active-color="#fff"
          autoplay circular
          style="height:{{item.cards[0]._height}}rpx">
          <swiper-item wx:for="{{item.cards}}" wx:for-item="card" wx:key="id">
            <view class="biz-card biz-card-swiper" style="height:{{card._height}}rpx"
              bindtap="onBizCardTap" data-module-id="{{card.id}}">
              <image wx:if="{{card.coverImage}}" class="biz-card-cover" src="{{card.coverImage}}" mode="aspectFill" />
              <view class="biz-card-info">
                <text class="biz-card-name">{{card.name}}</text>
  
              </view>
            </view>
          </swiper-item>
        </swiper>
        <view wx:if="{{item.displayLayout === 'grid'}}" class="profile-grid g-active" style="display:grid;grid-template-columns:repeat({{item.gridCols}},1fr);gap:{{item.gridCols === 3 ? '16' : '20'}}rpx">
          <view wx:for="{{item.cards}}" wx:for-item="card" wx:key="id"
            class="biz-card biz-card-grid" style="height:{{card._height}}rpx"
            bindtap="onBizCardTap" data-module-id="{{card.id}}">
            <image wx:if="{{card.coverImage}}" class="biz-card-cover" src="{{card.coverImage}}" mode="aspectFill" />
            <view class="biz-card-info">
              <text class="biz-card-name">{{card.name}}</text>

            </view>
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="intro-card card">
        <text class="section-title">核心业务</text>
        <text class="section-desc">暂无业务模块数据</text>
      </view>
    </block>
  </view>

  <!-- 企业荣誉 -->
  <view wx:if="{{showHonors}}" class="module-block">
    <view class="section-header">
      <text class="section-headline">{{honorsModuleName}}</text>
    </view>
    <view class="honors-gallery">
      <view wx:for="{{awards}}" wx:key="name" class="award-item {{item.offset ? 'award-offset' : ''}}">
        <image class="award-image" src="{{item.image}}" mode="aspectFill" />
        <view class="award-caption">
          <text class="award-name">{{item.name}}</text>
          <text class="award-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 企业项目 -->
  <view wx:if="{{showProjects}}" class="module-block">
    <view class="section-header">
      <text class="section-headline">{{projectsModuleName}}</text>
    </view>
    <scroll-view scroll-x type="custom" class="project-scroll" enable-flex>
      <view wx:for="{{projects}}" wx:key="name" class="project-card">
        <image class="project-image" src="{{item.image}}" mode="aspectFill" />
        <view class="project-badge">{{item.location}}，{{item.year}}</view>
        <view class="project-body">
          <text class="project-name">{{item.name}}</text>
          <text class="project-desc">{{item.desc}}</text>
          <view class="project-tags">
            <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="project-tag">{{tag}}</text>
          </view>
          <button class="project-btn">深度解析规格 →</button>
        </view>
      </view>
    </scroll-view>
  </view>

  </block>

  <view class="scroll-bottom-spacer"></view>
</scroll-view>
