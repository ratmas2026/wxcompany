.page-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 160rpx;
}

/* 名片卡片 */
.card-section {
  padding: 0 32rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}
.business-card {
  position: relative;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  color: #f6f7ff;
  overflow: hidden;
}
.card-bg-blur {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  filter: blur(40rpx);
}
.card-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.1);
  overflow: hidden;
  margin: 0 auto 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.card-info {
  text-align: center;
  margin-bottom: 40rpx;
}
.card-name {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
}
.card-title {
  display: block;
  font-size: 30rpx;
  opacity: 0.9;
  margin: 8rpx 0 12rpx;
}
.card-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
}
.card-badge text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.card-contact {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 32rpx;
}
.contact-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 20rpx;
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: 2rpx;
}
.contact-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.card-location {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20px);
  border-radius: 16rpx;
  color: #3a5f94;
}
.location-company {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
}
.location-addr {
  font-size: 20rpx;
  opacity: 0.8;
}
.location-arrow {
  margin-left: auto;
  font-size: 40rpx;
}

/* 快速操作 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: #586064;
  font-weight: 700;
}
.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #f1f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* Section */
.section {
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}
.section-heading {
  font-size: 36rpx;
  font-weight: 700;
  color: #3a5f94;
}
.section-chapter {
  font-size: 22rpx;
  color: #586064;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.video-block {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.video-cover {
  width: 100%;
  aspect-ratio: 16/9;
}
.video-play-btn {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  color: #ffffff;
  font-size: 56rpx;
}
.desc-card {
  padding: 32rpx;
  background: #f1f4f6;
  border-radius: 16rpx;
}
.desc-text {
  font-size: 24rpx;
  color: #586064;
  line-height: 1.7;
}

/* Honor Scroll */
.honor-scroll {
  display: flex;
  gap: 20rpx;
  white-space: nowrap;
}
.honor-card {
  min-width: 320rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
.honor-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}
.honor-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}
.honor-name {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.honor-desc {
  font-size: 22rpx;
  color: #586064;
}

/* Project */
.project-block {
  background: #f1f4f6;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.project-image-wrap {
  position: relative;
}
.project-cover {
  width: 100%;
  height: 320rpx;
}
.project-tag {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  background: #3a5f94;
  color: #ffffff;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}
.project-detail {
  padding: 32rpx;
}
.proj-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.proj-desc {
  display: block;
  font-size: 24rpx;
  color: #586064;
  margin-bottom: 20rpx;
}
.proj-link {
  background: none;
  border: none;
  color: #3a5f94;
  font-size: 26rpx;
  font-weight: 700;
  padding: 0;
  text-align: left;
}

/* Video Player Overlay */
.video-player-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}
.video-player {
  width: 100%;
  height: 60%;
}
.video-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
}
