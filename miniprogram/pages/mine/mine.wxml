<view class="page-container">
  <top-bar title="我的" icon="👤" showBack="{{false}}" />
  <!-- Profile Header -->
  <view class="profile-header signature-gradient">
    <view class="profile-bg"></view>
    <view class="profile-info">
      <view class="avatar-wrap">
        <image class="avatar" src="{{userInfo.avatar || '/images/hero-bg.jpg'}}" mode="aspectFill" />
        <view class="avatar-badge">👤</view>
      </view>
      <text class="profile-name">{{userInfo.nickName || '未登录'}}</text>
      <text class="profile-role">{{userInfo.title || '点击登录体验更多功能'}}</text>
    </view>
    <button
      wx:if="{{!isLoggedIn}}"
      class="login-entry"
      bindtap="onGoLogin"
    >
      登录 / 注册
    </button>
  </view>

  <!-- Stats -->
  <view class="stats-row" wx:if="{{isLoggedIn}}">
    <view class="stat-item">
      <text class="stat-num">{{stats.cards}}</text>
      <text class="stat-label">我的名片</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.inquiries}}</text>
      <text class="stat-label">咨询记录</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.collections}}</text>
      <text class="stat-label">收藏项目</text>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-section">
    <!-- Section 1 -->
    <view class="menu-group">
      <view
        wx:for="{{menuGroup1}}"
        wx:key="key"
        class="menu-item"
        bindtap="onMenuTap"
        data-key="{{item.key}}"
      >
        <view class="menu-icon signature-gradient">
          <text>{{item.icon}}</text>
        </view>
        <view class="menu-info">
          <text class="menu-title">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
        <text class="menu-arrow">→</text>
      </view>
    </view>

    <!-- Section 2 -->
    <view class="menu-group">
      <view
        wx:for="{{menuGroup2}}"
        wx:key="key"
        class="menu-item"
        bindtap="onMenuTap"
        data-key="{{item.key}}"
      >
        <view class="menu-icon" style="background: #f1f4f6;">
          <text>{{item.icon}}</text>
        </view>
        <view class="menu-info">
          <text class="menu-title">{{item.title}}</text>
        </view>
        <text class="menu-arrow">→</text>
      </view>
    </view>

    <!-- Section 3: 退出登录 -->
    <view class="menu-group" wx:if="{{isLoggedIn}}">
      <view class="menu-item" bindtap="onLogout">
        <view class="menu-icon" style="background: #fde8e8;">
          <text>🚪</text>
        </view>
        <view class="menu-info">
          <text class="menu-title logout-title">退出登录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Version -->
  <view class="version-text">
    <text>企业展示 v1.0.0</text>
  </view>

</view>
