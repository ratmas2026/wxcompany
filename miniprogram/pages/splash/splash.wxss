.splash-container {
  width: 100vw;
  height: 100vh;
  position: relative;
  background: #0f0f1a;
}

/* 兜底渐变背景 */
.splash-fallback {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 0;
}

.fallback-icon {
  font-size: 140rpx;
  margin-bottom: 32rpx;
}

.fallback-text {
  font-size: 44rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 8rpx;
}

/* 启动图 */
.splash-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 跳过按钮 - 胶囊正下方，左对齐同宽 */
.skip-btn {
  position: absolute;
  background: rgba(0, 0, 0, 0.3);
  color: rgba(255, 255, 255, 0.9);
  border: none;
  border-radius: 28rpx;
  padding: 8rpx 0;
  font-size: 22rpx;
  line-height: 1.4;
  text-align: center;
  z-index: 2;
}

/* 底部品牌标识 */
.bottom-area {
  position: absolute;
  bottom: 120rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.logo-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4);
}

.logo-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 4rpx;
  margin-top: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}
