.page-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 160rpx;
}

/* Hero */
.hero-section {
  position: relative;
  height: 300rpx;
  display: flex;
  align-items: flex-end;
  padding: 48rpx;
}
.hero-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.hero-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* Filter Bar */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  overflow-x: auto;
  white-space: nowrap;
}
.filter-bar::-webkit-scrollbar {
  display: none;
}
.filter-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #586064;
  background: #f1f4f6;
  transition: all 0.2s;
}
.filter-item--active {
  background: #3a5f94;
  color: #ffffff;
  font-weight: 700;
}

/* Image Grid */
.image-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 8rpx;
}
.grid-item {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  aspect-ratio: 4/3;
}
.grid-image {
  width: 100%;
  height: 100%;
}
.grid-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(0deg, rgba(0,0,0,0.6) 0%, transparent 50%);
  display: flex;
  align-items: flex-end;
  padding: 20rpx;
}
.grid-project {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.grid-stage {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: rgba(255,255,255,0.8);
}
.stage-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4ade80;
}

/* More */
.more-section {
  padding: 40rpx 32rpx;
}
.more-btn {
  width: 100%;
  padding: 28rpx;
  background: #f1f4f6;
  color: #3a5f94;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
