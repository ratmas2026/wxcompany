/* ============================================
   登录页 — 科技商务风 · 数字身份系统
   ============================================ */

.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f2f8 0%, #e8ecf4 40%, #dfe6f2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  position: relative;
  overflow: hidden;
}

/* ---- 背景柔光球 ---- */
.bg-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.bg-glow--top {
  width: 520rpx;
  height: 520rpx;
  top: -180rpx;
  right: -140rpx;
  background: radial-gradient(circle, rgba(102,126,234,0.13) 0%, transparent 70%);
}
.bg-glow--bottom {
  width: 400rpx;
  height: 400rpx;
  bottom: -120rpx;
  left: -100rpx;
  background: radial-gradient(circle, rgba(118,75,162,0.10) 0%, transparent 70%);
}

/* ---- 品牌区 ---- */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 140rpx;
  padding-bottom: 56rpx;
}
.brand-logo {
  font-size: 56rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(102,126,234,0.25));
}
.brand-slogan {
  font-size: 24rpx;
  color: #8a8fa8;
  letter-spacing: 8rpx;
  font-weight: 400;
}

/* ---- 毛玻璃卡片 ---- */
.login-card {
  width: 100%;
  background: rgba(255,255,255,0.62);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 48rpx 36rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(58,68,98,0.08),
              0 2rpx 8rpx rgba(58,68,98,0.04);
  border: 1rpx solid rgba(255,255,255,0.5);
}

/* ---- 卡片标题 ---- */
.card-header {
  text-align: center;
  margin-bottom: 48rpx;
}
.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2a3a;
  letter-spacing: 2rpx;
}
.card-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8a8fa8;
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* ---- 表单 ---- */
.login-form {
  width: 100%;
}

/* ---- 输入框 ---- */
.input-wrap {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  transition: box-shadow 0.25s ease;
}
.input-wrap--focused {
  box-shadow: 0 0 0 2rpx rgba(102,126,234,0.35);
}
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  background: rgba(255,255,255,0.55);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2a3a;
  border: none;
  box-sizing: border-box;
}
.input-placeholder {
  color: #b0b6c4;
}

/* ---- 验证码行 ---- */
.code-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
  align-items: center;
}
.code-input-wrap {
  flex: 7;
  border-radius: 16rpx;
  transition: box-shadow 0.25s ease;
}
.code-btn {
  flex: 3;
  padding: 0;
  height: 88rpx;
  background: rgba(255,255,255,0.55);
  color: #667eea;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.code-btn--disabled {
  color: #c0c4cc;
  background: rgba(245,247,250,0.6);
}

/* ---- 登录按钮 ---- */
.login-btn {
  width: 100%;
  height: 96rpx;
  padding: 0;
  color: #ffffff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(102,126,234,0.28);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.login-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(102,126,234,0.35),
              0 0 0 6rpx rgba(102,126,234,0.08);
}

/* ---- 协议 ---- */
.agreement-row {
  position: fixed;
  bottom: 48rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 26rpx;
  color: #b0b6c4;
  opacity: 0.65;
  white-space: nowrap;
}
.agree-circle {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 2rpx solid #c8cdd8;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  vertical-align: middle;
  box-sizing: border-box;
  margin-right: 6rpx;
}
.agree-circle--checked {
  background: #667eea;
  border-color: #667eea;
}
.agree-check {
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
}
.agree-link {
  color: #667eea;
}
