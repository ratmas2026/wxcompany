.login-page {
  min-height: 100vh;
  background: #efefef;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* Brand */
.brand-bg {
  background: linear-gradient(135deg, #3a5f94, #375c91);
}

/* Header */
.login-header {
  width: 100%;
  padding-top: 160rpx;
  padding-bottom: 80rpx;
}
.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2b3437;
}

/* Login Form */
.login-form {
  width: 100%;
}

/* Input */
.input-wrap {
  width: 100%;
  margin-bottom: 24rpx;
}
.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  border: none;
  box-sizing: border-box;
}
.input-placeholder {
  color: #b0b7bd;
}

/* Code Row */
.code-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 48rpx;
}
.code-input-wrap {
  flex: 3;
}
.code-btn {
  flex: 1;
  padding: 0 4rpx;
  background: #e8f4e8;
  color: #4caf50;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.code-btn--disabled {
  color: #abb3b7;
  background: #f1f4f6;
}

/* Login Button */
.login-btn {
  width: 100%;
  padding: 28rpx;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(58, 95, 148, 0.3);
}

/* Agreement */
.agreement-row {
  text-align: center;
  margin-top: auto;
  padding: 32rpx 0 48rpx;
  font-size: 24rpx;
  color: #999999;
  white-space: nowrap;
}
.agree-circle {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #c5cad0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  vertical-align: middle;
  box-sizing: border-box;
  margin-right: 8rpx;
}
.agree-circle--checked {
  background: #3a5f94;
  border-color: #3a5f94;
}
.agree-check {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}
.agree-link {
  color: #3a5f94;
}
