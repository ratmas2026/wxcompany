.login-page {
  min-height: 100vh;
  background: #F5F7FA;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx;
}

/* Title */
.login-header {
  width: 100%;
  padding-top: 160rpx;
  padding-bottom: 80rpx;
  text-align: center;
}
.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
}

/* Login Form */
.login-form {
  width: 100%;
}

/* Input */
.input-wrap {
  width: 100%;
  margin-bottom: 24rpx;
}
.form-input {
  width: 100%;
  height: 100rpx;
  padding: 0 32rpx;
  background: #FFFFFF;
  border-radius: 50rpx;
  font-size: 30rpx;
  color: #333333;
  border: none;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.input-placeholder {
  color: #999999;
}

/* Code Row */
.code-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 48rpx;
  align-items: center;
}
.code-input-wrap {
  flex: 7;
}
.code-btn {
  flex: 3;
  padding: 0;
  height: 100rpx;
  background: #FFFFFF;
  color: #1890FF;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
  border: 2rpx solid #1890FF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.code-btn--disabled {
  color: #C0C4CC;
  border-color: #E4E7ED;
  background: #F5F7FA;
}

/* Login Button */
.login-btn {
  width: 100%;
  height: 100rpx;
  padding: 0;
  color: #FFFFFF;
  background: #1890FF;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(24,144,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Agreement */
.agreement-row {
  text-align: center;
  margin-top: auto;
  padding: 32rpx 0 24rpx;
  font-size: 24rpx;
  color: #999999;
  white-space: nowrap;
}
.agree-circle {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #C0C4CC;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  vertical-align: middle;
  box-sizing: border-box;
  margin-right: 8rpx;
}
.agree-circle--checked {
  background: #1890FF;
  border-color: #1890FF;
}
.agree-check {
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 700;
}
.agree-link {
  color: #1890FF;
}

