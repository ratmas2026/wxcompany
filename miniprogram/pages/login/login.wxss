.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* Background */
.bg-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
  background: linear-gradient(135deg, #f8f9fa 0%, #f1f4f6 30%, rgba(58, 95, 148, 0.05) 100%);
}
.bg-image {
  width: 100%;
  height: 100%;
  opacity: 0.08;
  mix-blend-mode: multiply;
}

/* Top Bar */
.top-bar {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 64rpx 48rpx 0;
}
.logo-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.logo-text {
  font-weight: 800;
  font-size: 40rpx;
  color: #3a5f94;
  letter-spacing: -1rpx;
}

/* Login Area */
.login-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  position: relative;
  z-index: 10;
}

/* Glass Panel */
.glass-panel {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(24px);
  border-radius: 40rpx;
  padding: 64rpx 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 24rpx 48rpx rgba(43, 52, 55, 0.08);
}

/* Welcome */
.welcome-section {
  text-align: center;
  margin-bottom: 64rpx;
}
.welcome-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #2b3437;
  margin-bottom: 16rpx;
  letter-spacing: -1rpx;
}
.welcome-sub {
  font-size: 26rpx;
  color: #586064;
}

/* WeChat Button */
.wechat-btn {
  width: 100%;
  padding: 28rpx;
  color: #f6f7ff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(58, 95, 148, 0.2);
}

/* Divider */
.divider-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 0;
}
.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(171, 179, 183, 0.2);
}
.divider-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #586064;
  letter-spacing: 2rpx;
  white-space: nowrap;
}

/* Form Fields */
.field-group {
  margin-bottom: 32rpx;
}
.field-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #586064;
  margin-bottom: 12rpx;
  margin-left: 4rpx;
}
.input-wrap {
  position: relative;
}
.input-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  z-index: 1;
}
.form-input {
  width: 100%;
  padding: 24rpx 32rpx 24rpx 72rpx;
  background: #f1f4f6;
  border-radius: 24rpx;
  font-size: 28rpx;
  border: none;
  box-sizing: border-box;
}

/* Code Row */
.code-row {
  display: flex;
  gap: 16rpx;
}
.code-input-wrap {
  flex: 1;
}
.code-btn {
  padding: 24rpx 32rpx;
  background: #e3e9ec;
  color: #3a5f94;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  border: none;
  display: flex;
  align-items: center;
}
.code-btn--disabled {
  color: #abb3b7;
}

/* Login Button */
.login-btn {
  width: 100%;
  padding: 28rpx;
  background: rgba(58, 95, 148, 0.08);
  color: #3a5f94;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: 1rpx solid rgba(58, 95, 148, 0.15);
}

/* Privacy Links */
.privacy-links {
  margin-top: 48rpx;
  text-align: center;
}
.privacy-text {
  font-size: 22rpx;
  color: #586064;
  line-height: 1.6;
}
.privacy-link {
  color: #3a5f94;
  font-weight: 600;
}

/* Footer */
.page-footer {
  position: relative;
  z-index: 10;
  text-align: center;
  padding: 32rpx 48rpx 64rpx;
}
.footer-text {
  font-size: 18rpx;
  font-weight: 700;
  color: #abb3b7;
  letter-spacing: 4rpx;
}
