<view class="login-page">
  <!-- Title -->
  <view class="login-header">
    <text class="header-title">手机号码登录</text>
  </view>

  <!-- SMS Login Form (Primary) -->
  <view class="login-form">
    <form bindsubmit="onPhoneLogin">
      <!-- Phone Number -->
      <view class="input-wrap">
        <input
          class="form-input"
          name="phone"
          type="number"
          placeholder="请输入11位手机号"
          maxlength="11"
          placeholder-class="input-placeholder"
          bindinput="onPhoneInput"
          cursor-spacing="100"
          focus="{{autoFocus}}"
        />
      </view>

      <!-- Verification Code -->
      <view class="code-row">
        <view class="code-input-wrap">
          <input
            class="form-input"
            name="code"
            type="number"
            placeholder="6位验证码"
            maxlength="6"
            placeholder-class="input-placeholder"
            cursor-spacing="100"
          />
        </view>
        <button
          class="code-btn {{countdown > 0 || sendingCode ? 'code-btn--disabled' : ''}}"
          bindtap="onSendCode"
          disabled="{{countdown > 0 || sendingCode}}"
          loading="{{sendingCode}}"
        >
          {{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}
        </button>
      </view>

      <!-- Login Button -->
      <button class="login-btn" form-type="submit" loading="{{loggingIn}}" disabled="{{loggingIn}}">登录</button>
    </form>
  </view>

  <!-- Agreement -->
  <view class="agreement-row">
    <view class="agree-circle {{agreed ? 'agree-circle--checked' : ''}}" bindtap="onToggleAgree">
      <text wx:if="{{agreed}}" class="agree-check">✓</text>
    </view>
    <text>我已阅读并同意</text>
    <text class="agree-link" bindtap="onViewTerms">《用户协议》</text>
    <text>与</text>
    <text class="agree-link" bindtap="onViewPrivacy">《隐私政策》</text>
  </view>

</view>
