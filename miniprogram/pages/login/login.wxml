<view class="login-page">
  <!-- Header -->
  <view class="login-header">
    <text class="header-title">手机号码登录</text>
  </view>

  <!-- Login Form -->
  <view class="login-form">
    <form bindsubmit="onPhoneLogin">
      <!-- Phone Number -->
      <view class="input-wrap">
        <input
          class="form-input"
          name="phone"
          type="number"
          placeholder="请输入11位手机号"
          maxlength="11"
          placeholder-class="input-placeholder"
        />
      </view>

      <!-- Verification Code -->
      <view class="code-row">
        <view class="input-wrap code-input-wrap">
          <input
            class="form-input"
            name="code"
            type="number"
            placeholder="6位验证码"
            maxlength="6"
            placeholder-class="input-placeholder"
          />
        </view>
        <button
          class="code-btn {{countdown > 0 ? 'code-btn--disabled' : ''}}"
          bindtap="onSendCode"
          disabled="{{countdown > 0}}"
        >
          {{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}
        </button>
      </view>

      <!-- Login Button -->
      <button class="login-btn brand-bg" form-type="submit">登录</button>
    </form>
  </view>

  <!-- Agreement -->
  <view class="agreement-row">
    <view class="agree-circle {{agreed ? 'agree-circle--checked' : ''}}" bindtap="onToggleAgree">
      <text wx:if="{{agreed}}" class="agree-check">✓</text>
    </view>
    <text>我已阅读并同意</text>
    <text class="agree-link" bindtap="onViewTerms">《用户协议》</text>
    <text>与</text>
    <text class="agree-link" bindtap="onViewPrivacy">《隐私政策》</text>
  </view>
</view>
