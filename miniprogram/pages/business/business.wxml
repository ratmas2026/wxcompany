<view class="page-container">
  <!-- Hero -->
  <view class="hero-section signature-gradient">
    <view class="hero-overlay"></view>
    <view class="hero-content">
      <text class="hero-label">企业服务</text>
      <text class="hero-title">专业业务范围</text>
      <text class="hero-desc">全生命周期智能建筑解决方案</text>
    </view>
  </view>

  <!-- Tab Bar -->
  <scroll-view class="tab-bar" scroll-x enable-flex>
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="tab-item {{activeTab === item.value ? 'tab-item--active' : ''}}"
      data-tab="{{item.value}}"
      bindtap="onSwitchTab"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text>{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- Tab Content -->
  <view class="tab-content">
    <!-- Advantages -->
    <view class="section-card">
      <text class="section-title">核心优势</text>
      <view class="advantage-list">
        <view
          wx:for="{{currentTab.advantages}}"
          wx:key="index"
          class="advantage-item"
        >
          <view class="advantage-icon signature-gradient">
            <text>{{item.icon}}</text>
          </view>
          <view class="advantage-info">
            <text class="advantage-name">{{item.title}}</text>
            <text class="advantage-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Process -->
    <view class="section-card">
      <text class="section-title">服务流程</text>
      <view class="process-list">
        <view
          wx:for="{{currentTab.process}}"
          wx:key="index"
          class="process-item"
        >
          <view class="process-step">
            <text class="step-num">{{index + 1}}</text>
          </view>
          <view class="process-info">
            <text class="process-title">{{item.title}}</text>
            <text class="process-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Pricing -->
    <view class="section-card">
      <text class="section-title">服务报价</text>
      <view class="pricing-grid">
        <view
          wx:for="{{currentTab.pricing}}"
          wx:key="index"
          class="pricing-item"
        >
          <text class="pricing-name">{{item.name}}</text>
          <text class="pricing-price">{{item.price}}</text>
          <text class="pricing-unit">{{item.unit}}</text>
          <view class="pricing-features">
            <text
              wx:for="{{item.features}}"
              wx:key="index"
              class="pricing-feature"
            >✅ {{item}}</text>
          </view>
          <button class="pricing-btn" bindtap="onInquire" data-service="{{item.name}}">
            立即咨询
          </button>
        </view>
      </view>
    </view>
  </view>

</view>
