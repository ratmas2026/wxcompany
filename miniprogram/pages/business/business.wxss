.page-container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* Hero */
.hero-section {
  position: relative;
  height: 380rpx;
  display: flex;
  align-items: flex-end;
  padding: 48rpx;
  overflow: hidden;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.1) 0%, transparent 60%);
}
.hero-content {
  position: relative;
  z-index: 1;
}
.hero-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.hero-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* Tab Bar */
.tab-bar {
  display: flex;
  white-space: nowrap;
  background: #ffffff;
  padding: 16rpx 32rpx;
  gap: 16rpx;
}
.tab-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #586064;
  background: #f1f4f6;
}
.tab-item--active {
  background: #3a5f94;
  color: #ffffff;
  font-weight: 700;
}
.tab-icon {
  font-size: 28rpx;
}

/* Content */
.tab-content {
  padding: 32rpx;
}

/* Section Card */
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}
.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #2b3437;
  margin-bottom: 32rpx;
}

/* Advantages */
.advantage-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.advantage-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}
.advantage-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}
.advantage-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2b3437;
  margin-bottom: 4rpx;
}
.advantage-desc {
  font-size: 24rpx;
  color: #586064;
  line-height: 1.5;
}

/* Process */
.process-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}
.process-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}
.process-step {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #3a5f94;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.step-num {
  color: #ffffff;
  font-weight: 800;
}
.process-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2b3437;
  margin-bottom: 4rpx;
}
.process-desc {
  font-size: 24rpx;
  color: #586064;
}

/* Pricing */
.pricing-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.pricing-item {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
}
.pricing-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2b3437;
  text-align: center;
  margin-bottom: 8rpx;
}
.pricing-price {
  font-size: 48rpx;
  font-weight: 800;
  color: #3a5f94;
  text-align: center;
}
.pricing-unit {
  font-size: 22rpx;
  color: #586064;
  text-align: center;
  margin-bottom: 24rpx;
}
.pricing-features {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.pricing-feature {
  font-size: 22rpx;
  color: #586064;
}
.pricing-btn {
  width: 100%;
  padding: 18rpx;
  background: #3a5f94;
  color: #ffffff;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
  margin-top: auto;
}
