.page-container {
  min-height: 100vh;
  padding-bottom: 80rpx;
  background: #f8f9fa;
}

.detail-content {
  padding: 0 32rpx;
}

.detail-video {
  position: relative;
  width: 100%;
  height: 420rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  background: #eaeff1;
}
.detail-video-thumb {
  width: 100%;
  height: 100%;
}
.detail-video-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-play-btn {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-play-icon {
  color: #ffffff;
  font-size: 44rpx;
}

.detail-header {
  margin-bottom: 32rpx;
}
.detail-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a202c;
  line-height: 1.3;
}

.detail-body {
  margin-bottom: 40rpx;
}
.detail-body-rich {
  font-size: 28rpx;
  color: #4a5568;
  line-height: 1.8;
}

/* Video embed cards (outside rich-text) */
.detail-body-videos {
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.video-embed-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  background: #f0f4f8;
  border-radius: 16rpx;
  border: 2rpx dashed #c1c6d6;
}
.video-embed-card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #005bbf;
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.video-embed-card-info {
  flex: 1;
}
.video-embed-card-platform {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a202c;
  display: block;
}
.video-embed-card-id {
  font-size: 24rpx;
  color: #718096;
  margin-top: 4rpx;
}

.detail-section-label {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a202c;
  margin-bottom: 20rpx;
}

.detail-images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.detail-image-item {
  width: calc(33.33% - 8rpx);
  height: 240rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-empty {
  padding: 120rpx 0;
  text-align: center;
  color: #a0aec0;
  font-size: 28rpx;
}

/* Video Player Overlay */
.video-player-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}
.video-player {
  width: 100%;
  height: 60%;
}
.video-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
}
