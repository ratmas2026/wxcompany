.page-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 64rpx;
}

/* Top Bar */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 32rpx 24rpx;
}
.back-btn {
  font-size: 28rpx;
  color: #3a5f94;
  font-weight: 600;
}
.top-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2b3437;
}
.top-placeholder {
  width: 80rpx;
}

/* Card Preview */
.preview-section {
  padding: 32rpx;
  display: flex;
  justify-content: center;
}
.mini-card {
  width: 520rpx;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  position: relative;
  overflow: hidden;
}
.card-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 0%, rgba(255,255,255,0.2) 0%, transparent 70%);
}
.card-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.card-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.4);
  margin-bottom: 20rpx;
}
.card-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.card-title {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 32rpx;
}
.card-divider {
  width: 80rpx;
  height: 2rpx;
  background: rgba(255,255,255,0.3);
  margin-bottom: 32rpx;
}
.card-contact {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}
.card-contact text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}
.card-company {
  padding: 16rpx 40rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 32rpx;
}
.card-company text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

/* Share Section */
.share-section {
  padding: 48rpx 32rpx 32rpx;
}
.share-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2b3437;
  margin-bottom: 24rpx;
  text-align: center;
}
.share-grid {
  display: flex;
  justify-content: center;
  gap: 48rpx;
}
.share-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  background: none;
  border: none;
  padding: 0;
}
.share-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.share-label {
  font-size: 24rpx;
  color: #586064;
}

/* Poster */
.poster-section {
  padding: 32rpx;
}
.poster-preview {
  border-radius: 24rpx;
  overflow: hidden;
}
.poster-placeholder {
  height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}
.poster-icon {
  font-size: 64rpx;
}
.poster-tip {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 600;
}
