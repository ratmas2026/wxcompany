.page-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 160rpx;
}

/* Hero */
.hero-section {
  position: relative;
  height: 320rpx;
  display: flex;
  align-items: flex-end;
  padding: 48rpx;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 70%, rgba(255,255,255,0.1) 0%, transparent 60%);
}
.hero-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.hero-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* Content */
.content-area {
  padding: 32rpx;
}

/* QR Card */
.qr-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}
.qr-icon-wrap {
  margin-bottom: 20rpx;
}
.qr-icon {
  font-size: 56rpx;
}
.qr-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #2b3437;
  margin-bottom: 12rpx;
}
.qr-desc {
  font-size: 24rpx;
  color: #586064;
  margin-bottom: 32rpx;
}
.qr-code-wrap {
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto 24rpx;
  padding: 20rpx;
  background: #f1f4f6;
  border-radius: 20rpx;
}
.qr-code {
  width: 100%;
  height: 100%;
}
.qr-tip {
  font-size: 20rpx;
  color: #abb3b7;
}

/* Phone Card */
.phone-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}
.phone-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.phone-info {
  flex: 1;
}
.phone-label {
  display: block;
  font-size: 22rpx;
  color: #586064;
  margin-bottom: 4rpx;
}
.phone-number {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #2b3437;
  margin-bottom: 4rpx;
}
.phone-hours {
  font-size: 20rpx;
  color: #abb3b7;
}
.call-btn {
  padding: 20rpx 40rpx;
  background: #3a5f94;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
}

/* Office Card */
.office-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}
.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #2b3437;
  margin-bottom: 24rpx;
}
.office-address {
  margin-bottom: 16rpx;
}
.office-address text {
  font-size: 26rpx;
  color: #586064;
  line-height: 1.6;
}
