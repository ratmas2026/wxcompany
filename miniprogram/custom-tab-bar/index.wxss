.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  display: flex;
  align-items: center;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 9999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.tab-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #94a3b8;
  transition: all 0.15s;
}

.tab-selected .tab-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #3a5f94;
}
