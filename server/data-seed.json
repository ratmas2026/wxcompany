  "projects": [
    {
      "id": 1,
      "name": "Nexus 绿色天篷",
      "location": "新加坡",
      "year": 2023,
      "desc": "一个集成了40,000种原生植物的高密度住宅垂直森林。通过自然蒸腾作用将冷却成本降低了40%。",
      "tags": [
        "亲生物设计",
        "能源等级 A+",
        "城市更新"
      ],
      "image": "/images/project-1.jpg",
      "images": [
        "/images/hero-bg.jpg",
        "/images/office-bg.jpg",
        "/images/hero-bg.jpg",
        "/images/office-bg.jpg"
      ],
      "address": "新加坡滨海湾花园路88号",
      "scale": "总建筑面积 85,000㎡，地上45层，地下3层",
      "period": "2021年6月 - 2023年12月",
      "investment": "约 12.8 亿新加坡元",
      "highlights": [
        "全球首个超高层垂直森林住宅项目",
        "集成40,000种原生植物，自然蒸腾降温40%",
        "获新加坡Green Mark铂金认证",
        "亲生物设计理念引领城市更新潮流"
      ],
      "detail": "Nexus 绿色天篷是公司在新加坡承建的标杆性超高层生态建筑项目。项目采用亲生物设计理念，将40,000种原生植物融入建筑结构，形成独特的垂直森林生态系统。\n\n通过自然蒸腾作用，项目实现了被动降温，冷却成本降低40%。同时集成智能灌溉系统和植物健康监测平台，确保绿植墙体的可持续养护。\n\n项目获新加坡Green Mark铂金认证，成为城市更新与生态建筑融合的全球典范。",
      "detailImages": [
        "/images/hero-bg.jpg",
        "/images/office-bg.jpg"
      ]
    },
    {
      "id": 2,
